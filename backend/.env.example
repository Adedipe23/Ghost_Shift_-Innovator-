# GhostShift Backend Configuration

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=True
LOG_LEVEL=INFO

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_EXPIRES_IN=604800

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://ghostshift:ghostshift@postgres:5432/ghostshift
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=ghostshift
DATABASE_USER=ghostshift
DATABASE_PASSWORD=ghostshift

# Redis (for optional features)
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Rate Limiting
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW=60

# Demo Data
SEED_DEMO=true
