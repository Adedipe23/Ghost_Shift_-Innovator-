# GhostShift Backend - .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
logs.txt

# Database
*.db
*.sqlite
*.sqlite3

# IDE
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# Uploads
uploads/
*.upload

# Test artifacts (not the tests themselves)
*.test.py
*.spec.py
__tests__/

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Docker
# (GhostShift is containerised, so the Dockerfile IS tracked.)
# Dockerfile
# docker-compose.yml lives at project root and IS tracked.
# docker-compose.yml

# Backup files
*.backup
*.bak
